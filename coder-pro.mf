FROM qwen2.5-coder:14b

# On monte à 32k de contexte. C'est le max raisonnable pour tes 12Go de VRAM 
# tout en laissant de la place pour que le modèle réfléchisse.
PARAMETER num_ctx 32768

# On stabilise les réponses pour le code
PARAMETER temperature 0.1
PARAMETER top_p 0.9

# On lui donne son rôle pour qu'il arrête de demander "où coder"
SYSTEM """You are an expert AI software engineer. You have full access to the file system via the provided tools. 
When you need to see a file, read it. When you need to edit, use the write tool. 
Do not ask for permission, just execute the task in the current directory."""